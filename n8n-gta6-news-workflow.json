        {
            "parameters": {
                "jsCode": "const keywords = ['gta 6', 'gta vi', 'grand theft auto vi', 'grand theft auto 6', 'rockstar games gta', 'vice city'];\nconst results = [];\n\nfor (const item of $input.all()) {\n  const title = (item.json.title || '').toLowerCase();\n  const desc = (item.json.contentSnippet || item.json.description || '').toLowerCase();\n  const match = keywords.some(kw => title.includes(kw) || desc.includes(kw));\n  if (match) {\n    results.push(item);\n  }\n}\n\nif (results.length === 0) {\n  return [{ json: { _empty: true, message: 'No GTA 6 news found' } }];\n}\n\nreturn results;"
            },
            "id": "filter-gta6",
            "name": "Filtrar GTA 6",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                660,
                100
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": ""
                    },
                    "conditions": [
                        {
                            "id": "has-content",
                            "leftValue": "={{ $json._empty }}",
                            "rightValue": true,
                            "operator": {
