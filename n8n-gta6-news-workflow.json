        {
            "parameters": {
                "jsCode": "const results = [];\nfor (const item of $input.all()) {\n  const title = item.json.title || '';\n  const slug = title\n    .toLowerCase()\n    .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-z0-9\\s-]/g, '')\n    .replace(/\\s+/g, '-')\n    .replace(/-+/g, '-')\n    .substring(0, 80);\n  results.push({\n    json: {\n      ...item.json,\n      slug: slug\n    }\n  });\n}\nreturn results;"
            },
